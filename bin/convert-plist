#!/usr/bin/env bash

#
# convert-plist: Convert an OpenStep property list to/from XML
# shellcheck disable=SC2230 shell=bash
#
set -eo pipefail
usage="Usage: ${0##*/} [-h|--help] [-p|--print-format] [-x|--xml] plist"
print_format=
run_tests=
xml=

while [[ $1 =~ ^- ]]; do case $1 in
	-h|--help|-\?)     printf '%s\n' "$usage"; exit ;;
	-p|--print-format) print_format=1 ;;
	-t|--run-tests)    run_tests=1 ;;
	-x|--xml)          xml=1 ;;
	--)  shift; break ;;
	-?*) printf >&2 "${0##*/}: Invalid option: %s\n%s\n" "$1" "$usage"; exit 1 ;;
esac; shift; done

# Make sure pl(1) and plutil(1) are installed before we do anything
for cmd in plutil pl; do command >/dev/null 2>&1 -v "$cmd" || {
	printf >&2 "${0##*/}: Required command '%s' not found\n" "$cmd"
	exit 1
}; done

if [[ ! $run_tests ]]; then

# The plutil(1) utility refuses to read FIFOs for some reason
if [[ -p $1 || $1 == "-" ]]; then exec < "$1"; shift; fi

# Work out where our input is coming from
if [[ $# -gt 0 ]]; then
	# shellcheck disable=SC2059
	die()(printf >&2 "${0##*/}: $1\n" '"[4m'"$2"'[24m"'; exit 1)
	[[ -e $1 ]] || die 'No such file: %s' "$1"
	[[ -f $1 ]] || die 'Not a regular file: %s' "$2"
else set --; fi

# Scan first 6 bytes to determine file-format
read -r _ header <<END
$(dd 2>/dev/null bs=1 count=6 ${1:+if="$1"} | od -tx1)
END
header=${header// }
header=${header@U}
input_format=xml
case $header in
	62706C697374)     input_format=binary ;; # bplist
	7B*|28*|2F2[AF]*) input_format=ascii  ;; # { ( // /*
esac

# Print the name of the resolved format
if [[ $print_format ]]; then
	echo $input_format
	exit
fi

# Normalise formatting if both input and requested formats are XML
if [[ $input_format == xml && $xml ]]; then
	if [[ -t 0 ]]
		then exec plutil -convert xml1 "$1" -o -
		else {
			echo "$header" | xxd -p -r
			dd 2>/dev/null ${1:+if="$1"}
		} | exec plutil -convert xml1 - -o -
	fi

# Convert to XML
elif [[ $input_format == ascii ]]; then {
	if [[ ! -t 0 ]]; then
		echo "$header" | xxd -p -r
		dd 2>/dev/null ${1:+if="$1"}
	else
		cat "$1"
	fi
	echo # Ensure trailing newline
} | sed -E '
	:a
	/([=,({]|^)[[:blank:]]*"([^\\"]|\\[0-7]{1,3}|\\U[0-9A-Fa-f]{1,4}|\\.)*$/ { N; s/\n/\\n/g; ba
	}
	/<[^<>"]*$/ { N; s/\n[[:blank:]]*//; ba
	}
	s/([=,(]|^)[[:blank:]]*(<\[[^][<>]*\]>)/\1\n\2\n/g
	s/([=,(]|^)[[:blank:]]*(<\*D[^<>]*>)/\1\n\2\n/g
' | { while IFS= read -r line; do case $line in
	# Base64-encoded bytestring
	\<\[*\]\>)
		line="${line#??}"; line="${line%??}"
		printf '<'
		printf %s "$line" | base64 -d | xxd -u -p | tr -d ' \n\t'
		printf '>\n'
	;;
	# NSDate object
	\<\*D*\>)
		d='^<\*D[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])'
		d="$d (([01][0-9]|2[0-4])(:[0-5][0-9]){2})"
		d="$d [-+][0-9]{4}>$"
		if printf %s "$line" | grep -qE "$d"; then
			line="${line#*D}"; line="${line%\>}"
			fmt='%Y-%m-%d %H:%M:%S %z'
			TZ=UTC date -jf "$fmt" "$line" "+\"$fmt\""
		fi
	;;
	*) printf '%s\n' "$line";;
esac; done; } | {
	L='([=,(]|^)[[:blank:]]*'
	R='[[:blank:]]*($|[;,)])'
	sed -E "
		:a
		s/$L<\*B(Y|N)>$R/\1\"\2\"\3/gi;    ta
		s/$L<\*R([^<>]+)>$R/\1\"\2\"\3/gi; ta
		s/$L<\*I([^<>]+)>$R/\1\"\2\"\3/gi; ta
		s/$L(YES|NO|ON|OFF|TRUE|FALSE)$R/\1\"\2\"\3/gi; ta
		s/$L(-?[0-9]+)(e-?[0-9]+)$R/\1\"\2.0\3\"\4/gi;  ta
		s/$L(-?[0-9]*\.([0-9]*e-?)?[0-9]+|-?infinity|-?inf|nan)$R/\1\"\2\"\4/gi; ta
		s/$L(-?[0-9]+|-?0x[0-9A-F]+)$R/\1\"\2\"\3/gi; ta
		s/$L<\*D([^<>]*)>$R/\1\"\2\"\3/gi; ta
		s/\"([0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01]))[T ](([01][0-9]|2[0-4])(:[0-5][0-9]){2}) \+0000\"/\"\1T\4Z\"/g; ta
	";
} | plutil -convert xml1 - -o - | sed -E '
	s/<string>([0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-4])(:[0-5][0-9]){2}Z)<\/string>/<date>\1<\/date>/g
	s/<string>(Y|YES|ON|TRUE)<\/string>/<true\/>/gi
	s/<string>(N|NO|OFF|FALSE)<\/string>/<false\/>/gi
	s/<string>(-?[0-9]*\.([0-9]*[Ee]-?)?[0-9]+|-?infinity|-?inf|nan)<\/string>/<real>\1<\/real>/gi
	s/<string>(-?[0-9]+|-?0x[0-9A-F]+)<\/string>/<integer>\1<\/integer>/gi
'
	exit

# Convert to “ASCII” (OpenStep-flavoured property list)
else
	cmd=$(cat <<'SHELL'
	sed '
		/<string>\([^<]*\)<\/string>/ s/[]/&/g
		s/<data>/<string>/g
		s/<\/data>/<\/string>/g
		s/<true\/>/<string>YES<\/string>/g
		s/<false\/>/<string>NO<\/string>/g
		/<integer>\([^<]*\)<\/integer>/ {
			s//<string>\1<\/string>/g
			s/>+/>/g
			/>-\{0,1\}0[Xx]/ y/abcdefX/ABCDEFx/
		}
		/<real>\([^<]*\)<\/real>/ {
			s//<string>\1<\/string>/g
			s/\(>[-+]\{0,1\}\)[Ii][Nn][Ff]\([Ii][Nn][Ii][Tt][Yy]\)\{0,1\}</\1inf</g
			s/>+\{0,1\}inf</>+infinity</g
			s/>-\{0,1\}inf</>-infinity</g
			s/>[Nn][Aa][Nn]</>nan</g
			s/>+/>/g
			s/[Ee]+\([0-9]\{1,\}<\)/e\1/g
			s/[Ee]\(-\{0,1\}[0-9]\{1,\}<\)/e\1/g
			s/\(>-\{0,1\}[0-9]\{1,\}\)\(e-\{0,1\}[0-9]\{1,\}\)\{0,1\}</\1.0\2</g
			s/\(>-\{0,1\}\)\./\10./g
			s/\.e/.0e/g
		}
	' | (data=; have_data=;
	while IFS= read -r line; do
		case $line in
			*\</string\>)
				if [[ $have_data ]]; then
					printf '<string>\x11'
					printf %s "${data}${line%%\</string\>*}" \
						| tr -d '\020\021' | base64 -d | xxd -u -p | tr -d ' \n\t'
					printf '</string>'
					have_data=; data=
				else printf '%s\n' "$line"; fi ;;
			*\<string\>) have_data=1; data="${line##*\<string\>}" ;;
			*) [[ $have_data ]] && data="${data}${line}" || printf '%s\n' "$line" ;;
		esac
	done) | pl | sed '
		s/"YES"/YES/g
		s/"NO"/NO/g
		s/"\([^"]*\)"/<\1>/g
		s/"[]\([^"]*\)"/\1/g
		s/\([]\)/\1/g
		s/^[[:blank:]]*//g
		s/= *\([{(]\)$/= \1/g
	' | awk '
		BEGIN { depth = 0 }
		/[\)}][,;]?$/ { depth-- }
		{
			indent = ""
			for(i = 0; i < depth; ++i) indent = indent "\t"
			printf "%s%s\n", indent, $0
		}
		/[\({][,;]?$/ { depth++ }
	'
SHELL
	)
	if [[ $input_format == binary ]]; then
		cmd="plutil -convert xml1 - -o - | $cmd"
	else
		cmd="{ cat; printf '\n'; } | $cmd"
	fi
	if [[ -t 0 ]]; then
		eval "cat \"$1\" | $cmd"
	else
		eval "{
			echo \"$header\" | xxd -p -r;
			dd 2>/dev/null${1:+ if=\"$1\"};
		} | $cmd"
	fi
fi

# Run some built-in tests
else
command -v shellcheck >/dev/null 2>&1 && shellcheck "$0"

# Locate a highlighter for word-level diffs
hl=$(command -v diff-highlight 2>&1 || :)
[[ -x $hl ]] || for path in \
	"$(which git | xargs realpath | xargs dirname)/../share" \
	/usr/local/share \
	/usr/share \
; do
	path="$path/git-core/contrib/diff-highlight/diff-highlight"
	if [[ -f $path && -x $path ]]; then hl=$(realpath "$path"); break; fi
done

t(){
	diff -U4 "$@" | "${hl:-tee}" | sed '
		s/^--- .*/--- expected/
		s/^+++ .*/+++ actual/
		s/^-/[31m-/
		s/^+/[32m+/
		s/^@/[36m@/
		s/$/[0m/
	' | less -F
}

t <("$0" <<'PLIST'
{
	Foo = <466F6F>;
	foo = <
		66
		67
	>;
	str = "
		str
		ing
	";
}
PLIST
) <(cat <<'XML'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Foo</key>
	<data>
	Rm9v
	</data>
	<key>foo</key>
	<data>
	Zmc=
	</data>
	<key>str</key>
	<string>
		str
		ing
	</string>
</dict>
</plist>
XML
)

t <(echo '
62706C6973743030DF10100102030405060708090A0B0C0D0E0F10111213
1415161111111711111619111A5F10347061747465726E466F6C64657273
53686F776E3A364542333533314634354533444537323939323031354139
