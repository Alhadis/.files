<dict>
	<!-- Fundamentals -->
	<key>name</key><string>Man Page</string>
	<key>type</key><string>Window Settings</string>
	<key>ProfileCurrentVersion</key><real>2.07</real>
	
	<!-- Default to 80×40 dimensions -->
	<key>columnCount</key><integer>80</integer>
	<key>rowCount</key><integer>40</integer>
	
	<!-- Don't automatically close window when shell exits -->
	<key>shellExitAction</key><integer>2</integer>
	
	<!-- Options -->
	<key>CursorBlink</key><false/>
	<key>DisableANSIColor</key><false/>
	<key>ShowRepresentedURLInTitle</key><true/>
	<key>ShowTTYNameInTabTitle</key><false/>
	<key>ShowWindowSettingsNameInTitle</key><false/>
	<key>UseBrightBold</key><false/>
	<key>useOptionAsMetaKey</key><false/>
	
	<!-- Disable calls for user's attention -->
	<key>Bell</key><false/>
	<key>BellBadge</key><false/>
	<key>BellBounce</key><false/>
	<key>VisualBell</key><false/>
	
	<!-- Cursor shape (0 = Block, 1 = Underline, 2 = Vertical bar) -->
	<key>CursorType</key>
	<integer>0</integer>
	
	<!-- Text display -->
	<key>FontAntialias</key><true/>
	<key>FontHeightSpacing</key><integer>1</integer>
	<key>FontWidthSpacing</key><integer>1</integer>
	
